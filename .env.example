# Discord application credentials
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: register commands instantly in one development guild.
# Leave empty in production to use global commands.
DISCORD_GUILD_ID=

# Twitch application credentials and EventSub webhook configuration.
# Generate a unique secret; do not reuse a production value in local fixtures.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_EVENTSUB_SECRET=
TWITCH_EVENTSUB_CALLBACK_URL=https://example.com/webhooks/twitch/eventsub

# Runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
DEFAULT_LOCALE=en
